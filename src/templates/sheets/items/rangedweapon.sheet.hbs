
  <div class="item-sheet-body">
    <header class="item-sheet-header">
      <img class="item-sheet-img" data-edit="img" src="{{ item.img }}" alt="{{ item.name }}" />
      <div class="item-sheet-name">
        <label>{{localize 'sr4.weapon.name'}}</label>
        <input type="text" name="name" value="{{ item.name }}" />
      </div>
      <div class="item-sheet-header-extras">
        <label>
          <span>{{localize 'sr4.weapon.smartlink'}}</span>
          <input type="checkbox" class="sr4-checkbox" data-field="system.smartlink" {{#if system.smartlink}}checked{{/if}} />
        </label>
      </div>
    </header>

    <table class="item-stats-table">
      <thead>
        <tr>
          <th>{{localize 'sr4.weapon.attackSkill'}}</th>
          <th>{{localize 'sr4.weapon.damage'}}</th>
          <th>{{localize 'sr4.weapon.damageType'}}</th>
          <th>{{localize 'sr4.weapon.ap'}}</th>
          <th>{{localize 'sr4.weapon.armorType.label'}}</th>
          <th>{{localize 'sr4.weapon.mode'}}</th>
          <th>{{localize 'sr4.weapon.recoil'}}</th>
          <th>{{localize 'sr4.weapon.range'}}</th>
          <th>{{localize 'sr4.weapon.currentAmmo'}}</th>
          <th>{{localize 'sr4.weapon.maxAmmo'}}</th>
          <th>{{localize 'sr4.weapon.ammoFeed'}}</th>
          <th>{{localize 'sr4.weapon.avail'}}</th>
          <th>{{localize 'sr4.weapon.legality'}}</th>
          <th>{{localize 'sr4.weapon.cost'}}</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>
            <select name="system.attackSkill">
              {{selectOptions rangedattackskills selected=system.attackSkill localize=true}}
            </select>
          </td>
          <td><input type="number" name="system.damage" value="{{ system.damage }}" /></td>
          <td>
            <select name="system.damageType">
              {{selectOptions damagetypes selected=system.damageType localize=true}}
            </select>
          </td>
          <td>
            <input type="number" name="system.ap" value="{{ system.ap }}" />
          </td>
          <td>
            <select name="system.armorType">
              <option value="ballistic" {{#if (eq system.armorType "ballistic")}}selected{{/if}}>
                {{localize "sr4.weapon.armorType.ballistic"}}
              </option>
              <option value="impact" {{#if (eq system.armorType "impact")}}selected{{/if}}>
                {{localize "sr4.weapon.armorType.impact"}}
              </option>
            </select>
          </td>
          <td>
            <select name="system.mode">
              {{selectOptions shootingmodes selected=system.mode localize=true}}
            </select>
          </td>
          <td><input type="number" name="system.rc" value="{{ system.rc }}" /></td>
          <td><input type="text" name="system.range" value="{{ system.range }}" /></td>
          <td><input type="number" name="system.currentAmmo" value="{{ system.currentAmmo }}" /></td>
          <td><input type="number" name="system.maxAmmo" value="{{ system.maxAmmo }}" /></td>
          <td><input type="text" name="system.ammoFeed" value="{{ system.ammoFeed }}" /></td>
          <td><input type="number" name="system.avail" value="{{ system.avail }}" /></td>
          <td><input type="text" name="system.legality" value="{{ system.legality }}" /></td>
          <td><input type="number" name="system.cost" value="{{ system.cost }}" /></td>
        </tr>
      </tbody>
    </table>

    <div class="ammo-section">
      <label>{{localize 'sr4.ammo.loaded'}}</label>
      <select name="system.loadedAmmoId">
        <option value="">— {{localize 'sr4.ammo.none'}} —</option>
        {{#each availableAmmo as |a|}}
        <option value="{{ a.id }}" {{#if (eq ../system.loadedAmmoId a.id)}}selected{{/if}}>
          {{ a.name }}
        </option>
        {{/each}}
      </select>
      {{#if system.loadedAmmoName}}
      <small>({{localize 'sr4.ammo.effective'}}: {{localize 'sr4.weapon.damage'}} {{ system.effectiveDamage }} / {{localize 'sr4.weapon.ap'}} {{ system.effectiveAP }}{{#if (ne system.effectiveArmorType system.armorType)}} / {{localize 'sr4.weapon.armorType.label'}}: {{#if (eq system.effectiveArmorType "impact")}}{{localize "sr4.weapon.armorType.impact"}}{{else}}{{localize "sr4.weapon.armorType.ballistic"}}{{/if}}{{/if}})</small>
      {{/if}}
    </div>

    <div class="mods-section">
      <label>{{localize 'sr4.weaponmod.installed'}}</label>
      {{#if system.modSlotWarning}}
        <small class="warning">{{localize 'sr4.weaponmod.slotWarning'}}</small>
      {{/if}}
      <small>{{localize 'sr4.weaponmod.slotsUsed'}}: {{ system.usedModSlots }} / {{ system.modSlots }}</small>
      {{#if installedMods.length}}
      <ul class="installed-mods-list">
        {{#each installedMods as |mod|}}
        <li>
          <span>{{ mod.name }}</span>
          {{> item-edit-btn itemId=mod.id}}
          <button type="button" class="item-delete" data-action="removeMod" data-mod-id="{{ mod.id }}" data-tooltip="{{localize 'sr4.item.delete'}}"><i class="fas fa-times"></i></button>
        </li>
        {{/each}}
      </ul>
      {{/if}}
      {{#if availableWeaponMods.length}}
      <select data-action="addMod">
        <option value="">— {{localize 'sr4.weaponmod.add'}} —</option>
        {{#each availableWeaponMods as |m|}}
        <option value="{{ m.id }}">{{ m.name }}</option>
        {{/each}}
      </select>
      {{/if}}
      {{> item-create-btn btnAction="createMod" btnItemType="Weapon Mod" btnTooltip="sr4.weaponmod.add"}}
    </div>

    {{> "item-textareas"}}

  </div>
