<div class="item-sheet-body">
  {{> "item-sheet-header" nameKey="sr4.item.name"}}

  <table class="item-stats-table">
    <thead>
      <tr>
        <th>{{localize 'sr4.item.rating'}}</th>
        <th>{{localize 'sr4.armor.ballisticarmor'}}</th>
        <th>{{localize 'sr4.armor.impactarmor'}}</th>
        <th>{{localize 'sr4.item.capacity'}}</th>
        <th>{{localize 'sr4.item.avail'}}</th>
        <th>{{localize 'sr4.item.legality'}}</th>
        <th>{{localize 'sr4.item.cost'}}</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>
          <input
            type="number"
            name="system.rating"
            value="{{ system.rating }}"
          />
        </td>
        <td>
          <input
            type="number"
            name="system.ballisticarmor"
            value="{{ system.ballisticarmor }}"
          />
        </td>
        <td>
          <input
            type="number"
            name="system.impactarmor"
            value="{{ system.impactarmor }}"
          />
        </td>
        <td>
          <input
            type="number"
            name="system.capacity"
            value="{{ system.capacity }}"
          />
        </td>
        <td>
          <input type="text" name="system.avail" value="{{ system.avail }}" />
        </td>
        <td>
          <input
            type="text"
            name="system.legality"
            value="{{ system.legality }}"
          />
        </td>
        <td>
          <input type="number" name="system.cost" value="{{ system.cost }}" />
        </td>
      </tr>
    </tbody>
  </table>

  <div class="mods-section">
    <label>{{localize 'sr4.armormod.installed'}}</label>
    {{#if system.capacityWarning}}
      <small class="warning">{{localize 'sr4.armormod.capacityWarning'}}</small>
    {{/if}}
    <small>{{localize 'sr4.armormod.capacityUsed'}}: {{ system.usedCapacity }} / {{ system.maxCapacity }}</small>
    {{#if installedMods.length}}
    <ul class="installed-mods-list">
      {{#each installedMods as |mod|}}
      <li>
        <span>{{ mod.name }}</span>
        {{> item-edit-btn itemId=mod.id}}
        <button type="button" class="item-delete" data-action="removeMod" data-mod-id="{{ mod.id }}" data-tooltip="{{localize 'sr4.item.delete'}}"><i class="fas fa-times"></i></button>
      </li>
      {{/each}}
    </ul>
    {{/if}}
    {{#if availableArmorMods.length}}
    <select data-action="addMod">
      <option value="">— {{localize 'sr4.armormod.add'}} —</option>
      {{#each availableArmorMods as |m|}}
      <option value="{{ m.id }}">{{ m.name }}</option>
      {{/each}}
    </select>
    {{/if}}
    {{> item-create-btn btnAction="createMod" btnItemType="Armor Mod" btnTooltip="sr4.armormod.add"}}
  </div>

  {{> "item-textareas"}}
</div>
