<div
  class="modifiers-card tab {{ tab.cssClass }}"
  data-group="primary"
  data-tab="modifiers"
>
  <div class="modifier-grid">

    <div class="modifier-section">
      <h3>{{localize "sr4.modifiers.defense"}}</h3>
      {{> "modifier-field" label="sr4.bonus.soakBonus" name="system.modifiers.soakBonus" value=system.modifiers.soakBonus}}
      {{> "modifier-field" label="sr4.bonus.overflowBonus" name="system.modifiers.overflowBonus" value=system.modifiers.overflowBonus}}
      {{> "modifier-field" label="sr4.bonus.woundModBonus" name="system.modifiers.woundModBonus" value=system.modifiers.woundModBonus}}
      {{> "modifier-field" label="sr4.modifiers.woundModifier" value=system.derivedStats.woundModifier readonly=true}}
    </div>

    <div class="modifier-section">
      <h3>{{localize "sr4.modifiers.initiative.title"}}</h3>
      {{> "modifier-field" label="sr4.modifiers.initiative.physicalBonus" name="system.modifiers.initiative.bonuses.physical" value=system.modifiers.initiative.bonuses.physical}}
      {{> "modifier-field" label="sr4.modifiers.initiative.physicalPasses" name="system.modifiers.initiative.passes.physical" value=system.modifiers.initiative.passes.physical}}
      {{> "modifier-field" label="sr4.modifiers.initiative.astralBonus" name="system.modifiers.initiative.bonuses.astral" value=system.modifiers.initiative.bonuses.astral}}
      {{> "modifier-field" label="sr4.modifiers.initiative.astralPasses" name="system.modifiers.initiative.passes.astral" value=system.modifiers.initiative.passes.astral}}
      {{> "modifier-field" label="sr4.modifiers.initiative.matrixBonus" name="system.modifiers.initiative.bonuses.matrix" value=system.modifiers.initiative.bonuses.matrix}}
      {{> "modifier-field" label="sr4.modifiers.initiative.matrixPasses" name="system.modifiers.initiative.passes.matrix" value=system.modifiers.initiative.passes.matrix min=1}}
    </div>

    <div class="modifier-section">
      <h3>{{localize "sr4.modifiers.overview"}}</h3>
      {{> "modifier-field" label="sr4.modifiers.initiative.currentPhysical" value=system.modifiers.initiative.bonuses.physical readonly=true}}
      {{> "modifier-field" label="sr4.modifiers.initiative.currentAstral" value=system.modifiers.initiative.bonuses.astral readonly=true}}
      {{> "modifier-field" label="sr4.modifiers.initiative.currentMatrix" value=system.modifiers.initiative.bonuses.matrix readonly=true}}
      {{> "modifier-field" label="sr4.modifiers.initiative.currentPasses" value=system.derivedStats.passesString readonly=true}}
    </div>

  </div>
</div>
